import uuid
from datetime import datetime

from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session as DBSession

from backend.database import get_db
from backend.models import Node, Session as SessionModel, Turn, TurnNodeMatch
from backend.node_matcher import match_nodes
from backend.schemas import NodeState, TurnCreate, TurnItem, TurnResponse

router = APIRouter(prefix="/api/sessions", tags=["turns"])

_RECENT_CONTEXT_LIMIT = 5


# ── Mock AI ────────────────────────────────────────────────────────────────────

def _mock_ai_reply(user_content: str, recent_turns: list[Turn], nodes: list[Node]) -> str:
    """
    Minimal mock AI that echoes node names found in the message so the
    matcher can pick them up.  Clearly labelled as a mock / placeholder.
    """
    matched_names = [n.name for n in nodes if n.name in user_content and n.layer != "0"]
    if matched_names:
        names_str = "、".join(matched_names)
        return (
            f"【Mock AI】关于「{names_str}」：这是演示模式下的占位回复。"
            f"在真实实现中，AI 将根据上下文对「{names_str}」给出详细解释与示例。"
        )
    return (
        "【Mock AI】收到你的问题。这是演示模式下的占位回复，"
        "真实实现中 AI 将结合知识图谱上下文作出针对性回答。"
    )


# ── endpoint ──────────────────────────────────────────────────────────────────

@router.post("/{session_id}/turns", response_model=TurnResponse, status_code=201)
def create_turn(
    session_id: str,
    body: TurnCreate,
    db: DBSession = Depends(get_db),
) -> TurnResponse:
    # verify session exists
    session = db.query(SessionModel).filter(
        SessionModel.session_id == session_id
    ).first()
    if not session:
        raise HTTPException(status_code=404, detail="Session not found")

    # ① store user Turn
    user_turn_id = str(uuid.uuid4())
    user_turn = Turn(
        turn_id=user_turn_id,
        session_id=session_id,
        speaker="user",
        content=body.content,
        timestamp=datetime.utcnow(),
    )
    db.add(user_turn)
    db.flush()  # make sure user_turn is in DB before reading context

    # ② recent_context (last N turns, excluding the one just added)
    recent_turns: list[Turn] = (
        db.query(Turn)
        .filter(Turn.session_id == session_id, Turn.turn_id != user_turn_id)
        .order_by(Turn.timestamp.desc())
        .limit(_RECENT_CONTEXT_LIMIT)
        .all()
    )

    # ③ all nodes for this session
    all_nodes: list[Node] = (
        db.query(Node).filter(Node.session_id == session_id).all()
    )

    # ④ Mock AI reply
    ai_reply = _mock_ai_reply(body.content, recent_turns, all_nodes)

    # ⑤ store AI Turn
    ai_turn_id = str(uuid.uuid4())
    ai_turn = Turn(
        turn_id=ai_turn_id,
        session_id=session_id,
        speaker="assistant",
        content=ai_reply,
        timestamp=datetime.utcnow(),
    )
    db.add(ai_turn)
    db.flush()

    # ⑥ match nodes against user_content + ai_reply
    combined_text = body.content + " " + ai_reply
    matches = match_nodes(combined_text, all_nodes)

    matched_node_ids: list[str] = []
    updated_nodes: list[Node] = []
    now = datetime.utcnow()

    for node_id, confidence in matches:
        # write TurnNodeMatch (traceability — turn_id is NEVER NULL)
        db.add(TurnNodeMatch(
            id=str(uuid.uuid4()),
            turn_id=user_turn_id,
            node_id=node_id,
            confidence=confidence,
        ))
        matched_node_ids.append(node_id)

        # update Node.is_lit
        node = next(n for n in all_nodes if n.node_id == node_id)
        if not node.is_lit:
            node.is_lit = True
            node.lit_at = now
            updated_nodes.append(node)

    db.commit()
    # refresh updated nodes
    for node in updated_nodes:
        db.refresh(node)

    return TurnResponse(
        turn_id=user_turn_id,
        ai_reply=ai_reply,
        matched_node_ids=matched_node_ids,
        updated_nodes=[NodeState.model_validate(n) for n in updated_nodes],
    )


@router.get("/{session_id}/turns", response_model=list[TurnItem])
def list_turns(session_id: str, db: DBSession = Depends(get_db)) -> list[TurnItem]:
    session = db.query(SessionModel).filter(
        SessionModel.session_id == session_id
    ).first()
    if not session:
        raise HTTPException(status_code=404, detail="Session not found")

    turns = (
        db.query(Turn)
        .filter(Turn.session_id == session_id)
        .order_by(Turn.timestamp.asc())
        .all()
    )
    return [TurnItem.model_validate(t) for t in turns]
