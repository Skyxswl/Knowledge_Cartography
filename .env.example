# MiniMax deployment defaults. Keep the API key out of source control.
ZOOMMIND_LLM_PROVIDER=openai-compatible

# OpenAI-compatible chat-completions API settings.
# Examples of compatible base URLs:
# - OpenAI: https://api.openai.com/v1
# - DeepSeek: https://api.deepseek.com/v1
# - DashScope OpenAI-compatible mode: https://dashscope.aliyuncs.com/compatible-mode/v1
# - MiniMax Global: https://api.minimax.io/v1
# - MiniMax China: https://api.minimaxi.com/v1
ZOOMMIND_LLM_API_KEY=
ZOOMMIND_LLM_BASE_URL=https://api.minimaxi.com/v1
ZOOMMIND_LLM_MODEL=MiniMax-M2

ZOOMMIND_LLM_TIMEOUT_SECONDS=60
ZOOMMIND_LLM_TEMPERATURE=1.0
ZOOMMIND_LLM_MAX_TOKENS=700

# MiniMax models can split chain-of-thought-like reasoning into a separate field.
ZOOMMIND_LLM_REASONING_SPLIT=true

# Deployment
# Local default:
# DATABASE_URL=sqlite:///./app.db
# Render/Fly/Railway persistent disk example:
# DATABASE_URL=sqlite:////data/app.db
DATABASE_URL=sqlite:///./app.db

# Only needed when frontend and backend are deployed on different origins.
# For the recommended single-service Docker deployment, keep this unset.
# ZOOMMIND_CORS_ORIGINS=https://your-frontend.example.com
